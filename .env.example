OPENAI_API_KEY=<your-openai-api-key>

# TTS provider selection: "elevenlabs" (default) or "60db".
# Can also be overridden per-run with the --tts-provider flag.
TTS_PROVIDER=elevenlabs

# ElevenLabs
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# 60db (https://api.60db.ai) — only needed when TTS_PROVIDER=60db
SIXTYDB_API_KEY=<your-60db-api-key>
SIXTYDB_VOICE_ID=<your-60db-voice-id>
# Optional 60db tuning (defaults shown):
# SIXTYDB_BASE_URL=https://api.60db.ai
# SIXTYDB_SPEED=1
# SIXTYDB_STABILITY=50
# SIXTYDB_SIMILARITY=75
